# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Prefer pnpm in this repo (avoid committing npm/yarn lockfiles)
package-lock.json
yarn.lock

node_modules
.wrangler
dist
dist-ssr

# Env and secrets (Vite / Node / Wrangler)
.env
.env.local
.env.*.local
.env.production
.env.development
# Wrangler local secrets (API tokens, etc.) — never commit
.dev.vars

# Optional: commit a template with dummy values
!.env.example

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Keys / certs (if you ever add TLS or signing locally)
*.pem
*.p12
